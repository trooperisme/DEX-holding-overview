{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "data/raw/*.csv"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/dashboard",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}
