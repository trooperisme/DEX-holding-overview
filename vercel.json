{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/dashboard",
      "destination": "/api/index"
    }
  ]
}
